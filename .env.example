# Application Configuration
BASE_URL=http://localhost:5173
BACKEND_URL=http://localhost:3000
MONGODB_URI=mongodb://localhost:27017/demo-app

# Backend API Configuration
PORT=3000
JWT_SECRET=your-secret-key-here-change-in-production

# Frontend Configuration
VITE_API_URL=http://localhost:3000

# Test Configuration
TEST_TIMEOUT=30000
DEFAULT_NAVIGATION_TIMEOUT=30000
DEFAULT_ACTION_TIMEOUT=10000

# Browser Configuration
HEADLESS=false
SLOW_MO=0

# Test Data
TEST_DATA_DIR=./data/csv

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Screenshots & Videos
SCREENSHOT_ON_FAILURE=true
VIDEO_ON_FAILURE=true
TRACE_ON_FAILURE=true

# Parallel Execution
WORKERS=4
FULLY_PARALLEL=true

# Retry Configuration
RETRIES=0
RETRIES_CI=2

# Environment
NODE_ENV=development
CI=false

# Docker Network Configuration
# Uncomment these and update BASE_URL when running tests inside Docker
# BASE_URL=http://frontend:5173
# BACKEND_URL=http://backend:3000
# MONGODB_URI=mongodb://mongodb:27017/demo-app
