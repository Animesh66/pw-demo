{
  "name": "pw-demo",
  "version": "1.0.0",
  "description": "Playwright Test Automation Framework with Page Object Model",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:chrome": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "test:all-browsers": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:order": "playwright test --grep @order",
    "test:registration": "playwright test --grep @registration",
    "test:order-happy-path": "playwright test tests/order-test/order-happy-path.spec.ts",
    "test:order-negative": "playwright test tests/order-test/order-negative.spec.ts",
    "test:registration-happy-path": "playwright test tests/user-registration-test/user-registration-happy-path.spec.ts",
    "test:registration-negative": "playwright test tests/user-registration-test/user-registration-negative.spec.ts",
    "test:parallel": "playwright test --workers=4",
    "test:serial": "playwright test --workers=1",
    "test:report": "playwright show-report",
    "test:trace": "playwright show-trace",
    "test:codegen": "playwright codegen",
    "test:install": "playwright install",
    "test:allure": "playwright test --reporter=line,allure-playwright",
    "allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "allure:serve": "allure serve ./allure-results",
    "allure:clean": "rm -rf allure-results allure-report",
    "test:with-allure": "npm run allure:clean && npm run test:allure && npm run allure:generate && npm run allure:open",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf test-results playwright-report logs allure-results allure-report",
    "clean:auth": "rm -rf playwright/.auth",
    "pretest": "npm run type-check",
    "ci:test": "playwright test --reporter=html,json,junit,allure-playwright",
    "ci:install": "playwright install --with-deps"
  },
  "keywords": [
    "playwright",
    "test-automation",
    "e2e-testing",
    "page-object-model",
    "typescript"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "allure-commandline": "^2.32.1",
    "allure-playwright": "^3.1.0",
    "dotenv": "^16.4.7",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-playwright": "^1.8.3",
    "prettier": "^3.4.2",
    "typescript": "^6.0.3"
  }
}
